# --- Better Auth (email magic-link sign-in) ---
# 32+ char secret. Generate with: openssl rand -base64 32
BETTER_AUTH_SECRET=
# Public base URL of THIS frontend; used to build the magic-link URL.
BETTER_AUTH_URL=http://localhost:3000
# Postgres connection — the SAME database the agent uses. On Railway, reference
# the Postgres service, e.g. ${{Postgres.DATABASE_URL}}
DATABASE_URL=
# Optional: override the auth client base URL (defaults to the current origin).
NEXT_PUBLIC_BETTER_AUTH_URL=

# --- AgentMail (sends the magic-link email; server-side, keep secret) ---
# Same credentials the backend uses; add them to THIS frontend service too.
AGENTMAIL_API_KEY=
AGENTMAIL_INBOX_ID=
AGENTMAIL_FROM_EMAIL=
# Optional overrides:
# AGENTMAIL_BASE_URL=https://api.agentmail.to/v0
# AGENTMAIL_TIMEOUT_SECONDS=10
# Note: end-of-session feedback is handled by the Python backend (it generates
# Arche's reply and emails the user). The frontend route forwards it using
# SESSION_IDENTITY_SHARED_SECRET + BACKEND_API_URL (documented above) — no extra
# var needed here.

# --- Identity bridge (carry the verified user into the voice session) ---
# Shared secret proving the BFF route's server-to-server call is trusted, so the
# Python backend will attach the verified user_id to the LiveKit session.
# Must MATCH SESSION_IDENTITY_SHARED_SECRET on the backend service.
SESSION_IDENTITY_SHARED_SECRET=
# Server-side backend base URL the BFF route forwards to (defaults to
# NEXT_PUBLIC_API_URL if unset).
BACKEND_API_URL=

# --- Existing ---
# Backend base URL used to mint LiveKit sessions (/api/livekit/session).
NEXT_PUBLIC_API_URL=
# Inbound remote audio gain (1.0–2.0).
NEXT_PUBLIC_REMOTE_AUDIO_GAIN=1.35
