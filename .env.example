API_KEY=
API_BASE_URL=
SYSTEM_PROMPT=
ALLOWED_ORIGINS=http://localhost:3000,https://vigilant-youth-production-452c.up.railway.app
# Shared secret that lets the frontend BFF route assert a Better-Auth-verified
# user_id to /api/livekit/session. The backend only attaches user_id to the
# LiveKit session when the X-Internal-Auth header matches this. Must MATCH the
# frontend's SESSION_IDENTITY_SHARED_SECRET. Unset = identity ignored (anonymous).
SESSION_IDENTITY_SHARED_SECRET=

# LiveKit audio end-of-turn detector (livekit-agents >= 1.6.1). When enabled and
# available, replaces the vad/stt turn_detection mode with inference.TurnDetector.
# Feature-detected: on an older SDK it logs the blocker and keeps vad/stt.
LIVEKIT_TURN_DETECTOR_ENABLED=true
# auto | v1 | v1-mini. auto = SDK picks v1 (LiveKit Inference) else v1-mini (local).
LIVEKIT_TURN_DETECTOR_VERSION=auto
# Only tune after logs show premature commits / excessive dead air. Blank = default.
LIVEKIT_TURN_DETECTOR_UNLIKELY_THRESHOLD=
LIVEKIT_ENDPOINTING_DYNAMIC_ENABLED=true
# Inbound audio enhancement (applied before STT/VAD/turn detection).
LIVEKIT_AUDIO_ENHANCEMENT_ENABLED=true
LIVEKIT_AUDIO_ENHANCEMENT_PROVIDER=ai_coustics
LIVEKIT_AUDIO_ENHANCEMENT_MODEL=QUAIL_VF_S

# AudioInteraction shadow mode (observational only; never affects live audio).
# off = disabled entirely. shadow = fork user audio to the sidecar and log
# KEEP_SILENCE/TEXT_BEGIN decisions compared against TurnPolicy.
AUDIOINTERACTION_MODE=off
AUDIOINTERACTION_ENDPOINT=
AUDIOINTERACTION_TIMEOUT_MS=1000
# When true, sidecar text payloads are logged verbatim. Default false: only lengths.
AUDIOINTERACTION_DEBUG_TEXT=false
# Sidecar process only (scripts/audiointeraction_sidecar.py):
AUDIOINTERACTION_DEVICE=cpu
AUDIOINTERACTION_SIDECAR_PORT=5002
AUDIOINTERACTION_MODEL_ADAPTER=
AUDIOINTERACTION_BATCH_FRAMES=10

# Voice engine selection. current keeps the existing LiveKit STT/OpenRouter/Hume-TTS path.
# hume_evi keeps LiveKit as room/media layer and bridges room audio to Hume EVI.
VOICE_ENGINE=current

# --- TTS provider selection ---
# TTS_PROVIDER picks the primary voice: deepgram | hume | omnivoice.
# When the primary is omnivoice, TTS_FALLBACK_PROVIDER is used by LiveKit's
# FallbackAdapter if OmniVoice fails/times out/returns invalid audio, so the
# session never goes silent. Set TTS_FALLBACK_PROVIDER=none to disable fallback.
# Hume stays fully intact; leaving TTS_PROVIDER=hume behaves exactly as before.
TTS_PROVIDER=hume
TTS_FALLBACK_PROVIDER=hume

# --- OmniVoice TTS (HTTP sidecar) ---
# OmniVoice (https://github.com/k2-fsa/OmniVoice) runs as a separate service; the
# worker calls OMNIVOICE_URL/synthesize. MODEL_PATH/DEVICE describe the sidecar's
# model and are forwarded for informational use (the sidecar owns the weights).
OMNIVOICE_ENABLED=false
OMNIVOICE_URL=
# Optional: only set this if YOU put your own sidecar behind an auth proxy. It is
# NOT an OmniVoice credential (OmniVoice is just the open-source repo, no API).
# Blank = no Authorization header is sent.
OMNIVOICE_API_KEY=
OMNIVOICE_MODEL_PATH=
OMNIVOICE_DEVICE=cuda
OMNIVOICE_DEFAULT_LANGUAGE=en
OMNIVOICE_EXPRESSIVE_TAGS_ENABLED=true
# Sidecar I/O + validation knobs.
OMNIVOICE_TIMEOUT_SECONDS=10
OMNIVOICE_SAMPLE_RATE=24000
OMNIVOICE_AUDIO_FORMAT=wav
OMNIVOICE_MIN_AUDIO_BYTES=2048

# --- OmniVoice rotating voice-preset pool ---
# One warm/young/natural preset is selected per session and kept stable for that
# session (we never synthesize a fresh voice each time). The pool is a JSON file
# (see config/omnivoice_voice_pool.example.json). Rotation across sessions:
# random | weighted (by preset weight) | round_robin.
OMNIVOICE_VOICE_POOL_ENABLED=false
OMNIVOICE_VOICE_POOL_PATH=
OMNIVOICE_VOICE_ROTATION=random

# --- Structured planner + expressive delivery (PR 3) ---
# When enabled, the LLM returns a small JSON plan (response_text + intent +
# desired_delivery) and Arche adds at most one OmniVoice expressive tag and/or a
# bit of plain texture under cooldown rules. Default OFF keeps the existing
# token-streaming path untouched until verified against a live OmniVoice sidecar.
OMNIVOICE_EXPRESSIVE_PLANNER_ENABLED=false
# Bracket tags ~10-20% of turns; plain texture ~30-50%; low emotion confidence
# never forces a tag; never repeat the same tag/filler within the window.
OMNIVOICE_TAG_RATE=0.15
OMNIVOICE_FILLER_RATE=0.40
OMNIVOICE_EMOTION_CONFIDENCE_FLOOR=0.5
OMNIVOICE_NO_REPEAT_WINDOW=3

# --- Per-language LLM model routing (the multilingual "text quality" ceiling) ---
# OmniVoice can pronounce ~600 languages, but the LLM must write good text first.
# Route low-resource languages to a stronger model; English stays on the default.
# LLM_MODEL_BY_LANGUAGE: comma list of code=model (wins over the single override).
LLM_MODEL_BY_LANGUAGE=
# LLM_NON_ENGLISH_MODEL: one model used for any non-English active language.
LLM_NON_ENGLISH_MODEL=

# --- Inworld voice profile (weak emotional/vocal context; PR 4) ---
# Inworld's streaming STT (inworld/inworld-stt-1) returns a voiceProfile (emotion/
# vocalStyle/accent/age/pitch + confidence) which we normalize to
# {energy,tension,certainty,emotion_confidence,pitch,vocal_style,accent} and feed
# the planner as weak context — emotion labels are NEVER shown to the user.
# Voice profiling is English-only today; other languages yield a neutral profile.
# Set the key in Railway only; never commit it. Default OFF.
INWORLD_VOICE_PROFILE_ENABLED=false
INWORLD_API_KEY=
INWORLD_STT_WS_URL=wss://api.inworld.ai/stt/v1/transcribe:streamBidirectional
INWORLD_STT_MODEL_ID=inworld/inworld-stt-1
INWORLD_STT_SAMPLE_RATE=16000
# Only profile labels at/above this confidence are returned by Inworld.
INWORLD_VOICE_PROFILE_THRESHOLD=0.5
# Below this top-emotion confidence we collapse to a neutral profile (weak signal
# never forces an expressive tag).
INWORLD_EMOTION_CONFIDENCE_FLOOR=0.5
HUME_API_KEY=
HUME_SECRET_KEY=
HUME_EVI_CONFIG_ID=
HUME_EVI_VERSION=evi-3
HUME_EVI_WEBSOCKET_URL=wss://api.hume.ai/v0/evi/chat
HUME_CLM_BEARER_TOKEN=
HUME_EVI_BRIDGE_DEBUG=false
HUME_EVI_BRIDGE_LOG_AUDIO=false
HUME_EVI_SESSION_TIMEOUT_SECONDS=1800
# Default false: ignore Hume CLM model hints and use OPENROUTER_MODEL.
HUME_CLM_HONOR_MODEL_HINT=false
# Debug-only: capture generated Hume TTS audio before LiveKit/browser playout.
# Use this to compare Hume-generated WAV artifacts against heard cutoff artifacts.
HUME_TTS_CAPTURE_WAV_DEBUG=false
HUME_TTS_WAV_ARTIFACT_DIR=/tmp/lucy_hume_tts_artifacts
HUME_TTS_WAV_ARTIFACT_MAX_BYTES=12000000
# Trailing silence (ms) appended after TTS audio so a buffer drop at the
# speaking->listening transition trims silence instead of the final word/breath.
# 0 disables the hold (pure passthrough); clamped to 0..5000.
TTS_POST_SPEECH_HOLD_MS=0
# Handoff guard: if the user resumes with a real utterance while Arche is still
# thinking (no assistant audio yet), drop the stale pending reply before TTS.
# Off by default; once audio has started the normal interruption path applies.
LLM_TO_TTS_HANDOFF_GUARD_ENABLED=false
# Minimum sustained barge-in speech (ms) during thinking before it counts as a
# real new utterance (filters coughs/VAD blips). Clamped 0..5000.
HANDOFF_GUARD_MIN_SPEECH_MS=350
# Context-coherence layer (Phase 1, deterministic): judge whether the committed
# transcript plausibly fits the session (language mismatch / low ASR confidence).
# When low, the reply is shaped to acknowledge-and-attempt; turns are never
# blocked or silenced. Off by default.
CONTEXT_COHERENCE_ENABLED=false
# ASR confidence below this counts as low-coherence (clamped 0..1).
CONTEXT_COHERENCE_MIN_ASR_CONFIDENCE=0.45
# Active/session language Arche operates in; compared against the STT language
# candidate to detect language drift. Defaults to DEEPGRAM_STT_LANGUAGE or "en".
SESSION_LANGUAGE=en

# Context-policy layer: let detected prior-context signals govern prompt
# injection, response posture, and timeout fallback. Reuses existing context
# classification + turn policy; adds no new model/memory.
# LLM_MODEL is the existing OPENROUTER_MODEL knob (documented here for clarity).
LLM_MODEL=google/gemini-2.5-flash-lite
# Optional second model tried on first-token-timeout retry (best-effort; leave
# blank to re-request the same model). Not yet plumbed to a separate client.
LLM_FALLBACK_MODEL=
# Re-request once before speaking a fallback when the first token times out and
# nothing was emitted yet.
LLM_RETRY_ON_FIRST_TOKEN_TIMEOUT=true
# Fire tiny throwaway requests at worker startup to warm the OpenRouter
# generation model (and the transcript-context model when enabled) so the first
# real turn isn't paying connection/provider cold-start cost. Best-effort and
# non-blocking; runs concurrently with session setup and the greeting.
LLM_WARMUP_ENABLED=true
# Pre-render the fixed greeting to an in-memory WAV once at worker startup and
# serve every session's greeting from that buffer, so the first sound a user
# hears is instant and identical instead of paying a live Hume round-trip each
# session. The running worker holds the Hume key, so nothing needs committing.
# Auto-skipped when a static cached source (GREETING_USE_CACHED_AUDIO + URL/path)
# is configured, or when TTS_PROVIDER is not hume. Falls back to live TTS if the
# render is not ready when the greeting plays (typically only the first session
# after a cold worker boot).
GREETING_PRERENDER_AT_STARTUP=true
# --- Session time limit ---
# Hard cap per voice session. The worker speaks SESSION_ENDING_WARNING_TEXT about
# SESSION_ENDING_WARNING_SECONDS before the cap, then says the goodbye line and
# ends the room (the client lands on the end screen). Default: 7 min, 30s warning.
# Disable with SESSION_TIME_LIMIT_ENABLED=false or SESSION_MAX_DURATION_SECONDS=0.
# Both lines are spoken non-interruptibly and wait out any in-progress user
# speech so a barge-in can't swallow the heads-up. The reserve keeps a late
# heads-up from colliding with the goodbye; the goodbye wait is capped since the
# room tears down right after.
SESSION_TIME_LIMIT_ENABLED=true
SESSION_MAX_DURATION_SECONDS=420
SESSION_ENDING_WARNING_SECONDS=30
SESSION_ENDING_WARNING_TEXT=Hey, quick heads up — we've got about thirty seconds left for this one.
SESSION_ENDING_GOODBYE_TEXT=That's our time for now. Take care — talk soon.
SESSION_ENDING_WARNING_PLAYBACK_RESERVE_SECONDS=6
SESSION_ENDING_GOODBYE_CLEAR_WAIT_SECONDS=3
CONTEXT_POLICY_ENABLED=true
# Force the recent visible exchange into the prompt for context-dependent turns.
CONTEXT_FORCE_LOCAL_INJECTION=true
# How many recent visible turns to inject.
CONTEXT_INJECTION_TURNS=5
# Pass the context-dependent response posture into the prompt.
CONTEXT_RESPONSE_POSTURE_ENABLED=true
# Use a context-preserving fallback ("...pointing back to what just happened...")
# when a context-dependent turn times out.
CONTEXT_AWARE_FALLBACK_ENABLED=true
# Inherit a contextual intent forward 1-2 turns for short/vague/evaluative replies.
CONTEXT_REFERENCE_CARRY_FORWARD_ENABLED=true
# Exclude suppressed/zero-audio/interrupted assistant turns from injected context.
CONVERSATION_LEDGER_EXCLUDE_SUPPRESSED=true
# Emit prompt_context_injected / canonical history logs.
LOG_PROMPT_CONTEXT_INJECTION=true

# --- Context classifier handoff (timeouts protect latency, not authority) ---
# PRIMARY knob for the normal-turn classifier timeout. A timeout here only loses
# optional enrichment; the turn proceeds. Precedence:
#   NORMAL_CONTEXT_CLASSIFIER_MAX_WAIT_MS -> TRANSCRIPT_CONTEXT_LLM_TIMEOUT_MS -> default(500)
NORMAL_CONTEXT_CLASSIFIER_MAX_WAIT_MS=500
# PRIMARY knob for the high-risk tool/search revalidation timeout. The user is
# already waiting on a result, so we can wait longer to classify well. Precedence:
#   TOOL_REVALIDATION_CONTEXT_CLASSIFIER_MAX_WAIT_MS -> NORMAL_CONTEXT_CLASSIFIER_MAX_WAIT_MS
#   -> TRANSCRIPT_CONTEXT_LLM_TIMEOUT_MS -> default(1000)
TOOL_REVALIDATION_CONTEXT_CLASSIFIER_MAX_WAIT_MS=1000
# LEGACY/back-compat only. Both paths fall back to this if the clear vars above
# are unset; prefer the vars above going forward.
# TRANSCRIPT_CONTEXT_LLM_TIMEOUT_MS=500
# When true, a stale tool/search result may not regain the right to speak unless
# context resolved (or deterministic evidence is clearly safe). Fails safe.
REQUIRE_CONTEXT_RESOLUTION_FOR_TOOL_AUTHORITY=true
# Minimum dependency for a mid-search barge-in to count as additive enough to
# compose with the pending result. Allowed: high | medium | low. Default high.
TOOL_REVALIDATION_ADDITIVE_MIN_DEPENDENCY=high
