API_KEY=
API_BASE_URL=
SYSTEM_PROMPT=
ALLOWED_ORIGINS=http://localhost:3000,https://vigilant-youth-production-452c.up.railway.app

# AudioInteraction shadow mode (observational only; never affects live audio).
# off = disabled entirely. shadow = fork user audio to the sidecar and log
# KEEP_SILENCE/TEXT_BEGIN decisions compared against TurnPolicy.
AUDIOINTERACTION_MODE=off
AUDIOINTERACTION_ENDPOINT=
AUDIOINTERACTION_TIMEOUT_MS=1000
# When true, sidecar text payloads are logged verbatim. Default false: only lengths.
AUDIOINTERACTION_DEBUG_TEXT=false
# Sidecar process only (scripts/audiointeraction_sidecar.py):
AUDIOINTERACTION_DEVICE=cpu
AUDIOINTERACTION_SIDECAR_PORT=5002
AUDIOINTERACTION_MODEL_ADAPTER=
AUDIOINTERACTION_BATCH_FRAMES=10
